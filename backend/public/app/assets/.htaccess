# Vite emits content-hashed filenames for everything in this directory,
# so it's safe to cache them aggressively — a changed file gets a new name.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/javascript text/css application/json
</IfModule>
